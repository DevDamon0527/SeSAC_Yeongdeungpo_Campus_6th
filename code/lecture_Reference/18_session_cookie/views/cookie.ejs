<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
  </head>
  <body>
    <p>여기는 메인입니당</p>

    <a href="/setCookie">쿠키 설정하기</a>
    <a href="/getCookie">쿠키 확인하기</a>
    <a href="/clearCookie">쿠키 제거하기</a>

    <script>
      // Front 단에서 쿠키 생성해보기
      document.cookie = 'user=kdt; expires=13 DEC 2022 13:00:00 GMT';
      document.cookie = 'testKey=testValue; expires=13 DEC 2022 13:00:00 GMT';
      console.log(document.cookie);

      let cookieArr = document.cookie.split(';');
      console.log(cookieArr);
      for (let i in cookieArr) {
        console.log(cookieArr[i].trim());
      }
    </script>
  </body>
</html>
